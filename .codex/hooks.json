{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$(git rev-parse --show-toplevel)/.codex/hooks/lint.py\"",
            "timeout": 30,
            "statusMessage": "Running ruff check"
          },
          {
            "type": "command",
            "command": "uv run \"$(git rev-parse --show-toplevel)/.codex/hooks/format.py\"",
            "timeout": 30,
            "statusMessage": "Running ruff format"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"$(git rev-parse --show-toplevel)/.codex/hooks/file_budget.py\"",
            "timeout": 30,
            "statusMessage": "Checking file budgets"
          }
        ]
      }
    ]
  }
}
